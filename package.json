{
  "name": "park-recommender",
  "version": "1.0.0",
  "description": "CLI Agent for recommending parks and hiking spots in Shenzhen",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "park-recommender": "./dist/index.js"
  },
  "scripts": {
    "dev": "npm run build && npm link && npm run dev:watch",
    "dev:build": "npm run build && npm link",
    "dev:watch": "tsx src/index.ts",
    "build": "tsc && node scripts/fix-paths.cjs",
    "prebuild": "npm run clean",
    "postbuild": "chmod +x dist/index.js 2>/dev/null || true",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "node --loader tsx src/__tests__/runner.ts",
    "test:unit": "node --loader tsx src/__tests__/runner.ts --filter unit",
    "test:integration": "node --loader tsx src/__tests__/runner.ts --filter integration",
    "test:e2e": "node --loader tsx src/__tests__/runner.ts --filter e2e",
    "test:perf": "node --loader tsx src/__tests__/runner.ts --filter performance",
    "test:llm": "tsx scripts/test-llm.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "agent",
    "park",
    "hiking",
    "shenzhen",
    "recommendation",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "openai": "^4.24.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  }
}
