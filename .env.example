# LLM Configuration
# Choose your LLM provider: openai or anthropic
LLM_PROVIDER=openai

# OpenAI Compatible (e.g., Aliyun DashScope, Azure OpenAI)
# Get your API key from: https://dashscope.console.aliyun.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=qwen-turbo
# For Aliyun DashScope (OpenAI Compatible):
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# For standard OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4-turbo

# Alternative: Anthropic Claude
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Map API Configuration
# Get your Amap API key from: https://lbs.amap.com/
AMAP_API_KEY=your_amap_api_key_here
AMAP_BASE_URL=https://restapi.amap.com/v3

# Application Configuration
APP_NAME=深圳公园景点推荐 Agent
NODE_ENV=development
DEBUG=false

# Cache Configuration
CACHE_DIR=.cache
CACHE_EXPIRATION=604800

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
