# LLM Configuration
# Choose your LLM provider: openai, anthropic, or aliyun
LLM_PROVIDER=aliyun

# OpenAI
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Aliyun Bailian (阿里云百炼)
# Get your API key from: https://dashscope.console.aliyun.com/
ALIYUN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALIYUN_MODEL=qwen-plus
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Map API Configuration
# Get your Amap API key from: https://lbs.amap.com/
AMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AMAP_BASE_URL=https://restapi.amap.com/v3

# Application Configuration
APP_NAME=深圳公园景点推荐 Agent
NODE_ENV=development
DEBUG=false

# Cache Configuration
CACHE_DIR=.cache
CACHE_EXPIRATION=604800

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
