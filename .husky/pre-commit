#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo ""
echo "╔════════════════════════════════════════════════════════════╗"
echo "║            🔍 Pre-Commit: Running Tests                    ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""

npm run test

if [ $? -ne 0 ]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════╗"
  echo "║             ❌ Tests Failed - Commit Blocked               ║"
  echo "╚════════════════════════════════════════════════════════════╝"
  echo ""
  echo "💡 修复失败的测试后重新提交："
  echo "   npm run test                 - 运行所有测试"
  echo ""
  exit 1
fi

echo ""
echo "╔════════════════════════════════════════════════════════════╗"
echo "║             ✅ Tests Passed - Committing                   ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""
